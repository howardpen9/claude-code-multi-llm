# === Provider API Keys (at least one required) ===
OPENAI_API_KEY=sk-...
GOOGLE_API_KEY=AI...

# === Router Defaults ===
# DEFAULT_TIER=standard          # basic|standard|advanced|frontier
# DEFAULT_MODEL=                 # Force specific model (bypasses routing)
# MAX_BUDGET_PER_REQUEST=        # USD cap per single request (e.g. 0.10)
# PREFERRED_PROVIDER=            # Tiebreaker: openai or google

# === Cost Tracking ===
# COST_LOG_PATH=~/.llm-router/cost-log.jsonl
# BASELINE_MODEL=claude-opus-4   # "expensive" model for savings calculation
