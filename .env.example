# === Getting Started ===
# Set at least ONE API key to enable API router mode.
# No API key needed for CLI subscription mode (cli_ask) — just install the CLIs.

# === Provider API Keys ===
OPENAI_API_KEY=sk-...         # For GPT-4.1-mini, GPT-4.1, o3-mini, GPT-5
GOOGLE_API_KEY=AI...          # For Gemini Flash-Lite, Flash, Pro

# === Router Defaults ===
# DEFAULT_TIER=standard          # Minimum quality: basic|standard|advanced|frontier
# DEFAULT_MODEL=                 # Force specific model (bypasses auto-routing)
# MAX_BUDGET_PER_REQUEST=        # Max USD per single request (e.g. 0.10)
# PREFERRED_PROVIDER=            # Tiebreaker when costs are equal: openai | google

# === Cost Tracking ===
# COST_LOG_PATH=~/.llm-router/cost-log.jsonl   # JSONL log of every request
# BASELINE_MODEL=claude-opus-4   # Reference model for savings % in cost_report
#                                 # (compares actual cost vs "what if Opus handled this?")
