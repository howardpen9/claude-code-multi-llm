{
  "name": "claude-code-multi-llm",
  "version": "2026.3.4",
  "description": "Cost-saving LLM router for Claude Code — delegate subtasks to cheaper models via MCP",
  "type": "module",
  "bin": {
    "claude-code-multi-llm": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist/",
    "commands/",
    "skills/",
    ".claude-plugin/",
    "bin/",
    "LICENSE",
    "README.md",
    "README.zh-TW.md",
    "CHANGELOG.md"
  ],
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:validate": "bash tests/validate-commands.sh",
    "test:smoke": "bash tests/smoke-test.sh",
    "test:all": "vitest run && bash tests/validate-commands.sh && bash tests/smoke-test.sh",
    "analyze": "tsx src/analyze.ts",
    "benchmark": "bash tests/run-benchmark.sh",
    "lint": "bash tests/validate-commands.sh",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run test && npm run build",
    "postinstall": "node bin/postinstall.js || true"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/howardpen9/claude-code-multi-llm.git"
  },
  "homepage": "https://github.com/howardpen9/claude-code-multi-llm#readme",
  "bugs": {
    "url": "https://github.com/howardpen9/claude-code-multi-llm/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.0",
    "@modelcontextprotocol/sdk": "^1.26.0",
    "openai": "^4.80.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  },
  "author": "smartchoice",
  "license": "MIT",
  "keywords": [
    "mcp",
    "llm",
    "router",
    "claude-code",
    "cost-optimization",
    "multi-llm",
    "openai",
    "gemini",
    "codex",
    "kimi",
    "model-context-protocol"
  ]
}
